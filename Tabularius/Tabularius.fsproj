<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <PublishDir>bin\publish</PublishDir>
        <PublishTrimmed>true</PublishTrimmed>
        <PublishSingleFile>true</PublishSingleFile>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\HledgerInterop\bin\$(SharedLibName)"
              CopyToOutputDirectory="PreserveNewest"
              Link="$(SharedLibName)" />
    </ItemGroup>

    <!-- On Linux: also include bundled GHC runtime .so files -->
    <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
        <None Include="..\HledgerInterop\bin\libHS*.so"
              CopyToOutputDirectory="PreserveNewest"
              LinkBase="." />
    </ItemGroup>
    <ItemGroup>
      <ProjectReference Include="..\Tabularius.Interop\Tabularius.Interop.csproj" />
    </ItemGroup>
    <ItemGroup>
      <Compile Include="Program.fs" />
    </ItemGroup>

</Project>
