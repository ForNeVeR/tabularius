<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Tabularius.ViewModels"
             xmlns:tabularius="clr-namespace:Tabularius"
             xmlns:views="clr-namespace:Tabularius.Views"
             xmlns:resources="clr-namespace:Tabularius.Resources;assembly=Tabularius.Resources"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="50"
             x:Class="Tabularius.Views.StatusBar"
             x:DataType="viewModels:StatusViewModel">
    <Design.DataContext>
        <viewModels:StatusViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="*,Auto">
        <ItemsControl Grid.Column="0" ItemsSource="{Binding Activities}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="tabularius:BackgroundActivityEntry">
                    <views:ActivityIndicator/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Command="{Binding ThrowError}" Content="{x:Static resources:Localization.StatusBar_TestError}" IsVisible="{Binding IsErrorDiagnosticMode}"/>
            <Button Command="{Binding ShowErrorList}"
                    Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                <views:ErrorCounterIndicator/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
