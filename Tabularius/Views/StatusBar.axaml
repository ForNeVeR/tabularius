<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Tabularius.ViewModels"
             xmlns:views="clr-namespace:Tabularius.Views"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="50"
             x:Class="Tabularius.Views.StatusBar"
             x:DataType="viewModels:StatusViewModel">
    <Design.DataContext>
        <viewModels:StatusViewModel/>
    </Design.DataContext>

    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Command="{Binding ThrowError}">Test Error</Button>
        <views:ErrorCounterIndicator/>
    </StackPanel>
</UserControl>
