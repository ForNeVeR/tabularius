<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tabularius.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resources="clr-namespace:Tabularius.Resources;assembly=Tabularius.Resources"
        xmlns:views="clr-namespace:Tabularius.Views"
        Icon="/icon.ico"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="250"
        x:Class="Tabularius.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{x:Static resources:Localization.MainWindow_Title}">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*, Auto" ColumnDefinitions="*, Auto">

        <Label Grid.Column="0" Grid.Row="0" Content="{Binding JournalInfo}"/>
        <Button Grid.Column="1" Grid.Row="0"
                Content="{x:Static resources:Localization.MainWindow_LoadJournal}"
                Command="{Binding OpenJournal}"/>

        <views:StatusBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                         DataContext="{Binding Status}"/>
    </Grid>
</Window>
