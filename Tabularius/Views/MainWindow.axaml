<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tabularius.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:resources="clr-namespace:Tabularius.Resources;assembly=Tabularius.Resources"
        xmlns:views="clr-namespace:Tabularius.Views"
        Icon="/icon.ico"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="250"
        x:Class="Tabularius.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{x:Static resources:Localization.WindowTitle}">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid>
        <views:StatusBar/>
    </Grid>
</Window>
